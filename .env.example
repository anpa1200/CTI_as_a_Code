# ─────────────────────────────────────────────────────────────────────────────
# CTI Lab — Environment Variables
# Copy this file to .env and fill in all values before running docker compose.
# Generate secrets with: openssl rand -hex 32
# Generate UUIDs with:   cat /proc/sys/kernel/random/uuid
# ─────────────────────────────────────────────────────────────────────────────

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ELASTIC_PASSWORD=ChangeMe_Elastic123!

# ── Kibana ────────────────────────────────────────────────────────────────────
# Password for the built-in kibana_system user (set by setup.sh)
KIBANA_SYSTEM_PASSWORD=ChangeMe_Kibana123!
# Must be 32+ characters; used to encrypt saved objects
KIBANA_ENCRYPTION_KEY=00000000000000000000000000000000replace_this_32char_key

# ── MinIO (S3-compatible object store) ────────────────────────────────────────
MINIO_ROOT_USER=cti_minio
MINIO_ROOT_PASSWORD=ChangeMe_Minio123!

# ── RabbitMQ (OpenCTI message broker) ─────────────────────────────────────────
RABBITMQ_DEFAULT_USER=cti_rabbit
RABBITMQ_DEFAULT_PASS=ChangeMe_Rabbit123!

# ── OpenCTI ───────────────────────────────────────────────────────────────────
OPENCTI_ADMIN_EMAIL=admin@cti-lab.local
OPENCTI_ADMIN_PASSWORD=ChangeMe_CTI123!
# Application secret (JWT signing) — generate: openssl rand -hex 32
OPENCTI_APP_SECRET=replace_with_64_char_hex_string_here_use_openssl_rand_hex_32aa
# Admin API token — generate: cat /proc/sys/kernel/random/uuid
OPENCTI_ADMIN_TOKEN=00000000-0000-0000-0000-000000000001

# ── OpenCTI Connectors (each needs a unique UUID) ─────────────────────────────
# cat /proc/sys/kernel/random/uuid
CONNECTOR_MITRE_ID=00000000-0000-0000-0000-000000000002

# ── TheHive ───────────────────────────────────────────────────────────────────
# Application secret — generate: openssl rand -hex 32
THEHIVE_SECRET=replace_with_64_char_hex_string_here_use_openssl_rand_hex_32bb

# ── Cortex ────────────────────────────────────────────────────────────────────
# Application secret — generate: openssl rand -hex 32
CORTEX_SECRET=replace_with_64_char_hex_string_here_use_openssl_rand_hex_32cc
